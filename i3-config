# =============================================================================
# i3 config - Nord theme, clean setup
# =============================================================================

set $mod Mod4
font pango:FontAwesome 9, Poppins Regular 9

# Autostart
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock -c 000000 --nofork
exec --no-startup-id nm-applet
exec --no-startup-id picom --backend glx --no-fading-openclose

# =============================================================================
# KEYBINDINGS
# =============================================================================

# Terminal
bindsym $mod+Return exec i3-sensible-terminal

# Kill window
bindsym $mod+Shift+q kill

# App launcher (adi1090x/rofi type-1)
bindsym $mod+space exec --no-startup-id ~/.config/rofi/launchers/type-1/launcher.sh
bindsym $mod+d exec --no-startup-id ~/.config/rofi/launchers/type-1/launcher.sh

# Power menu (adi1090x/rofi type-1)
bindsym $mod+Shift+e exec --no-startup-id ~/.config/rofi/powermenu/type-1/powermenu.sh

# Screenshot
bindsym Print exec --no-startup-id scrot ~/Pictures/screenshot-%Y%m%d-%H%M%S.png
bindsym $mod+Print exec --no-startup-id scrot -s ~/Pictures/screenshot-%Y%m%d-%H%M%S.png

# Volume
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

# Brightness
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set +5%
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 5%-

# Media
bindsym XF86AudioPlay exec --no-startup-id playerctl play-pause
bindsym XF86AudioNext exec --no-startup-id playerctl next
bindsym XF86AudioPrev exec --no-startup-id playerctl previous

# =============================================================================
# WINDOW MANAGEMENT
# =============================================================================

floating_modifier $mod
tiling_drag modifier titlebar

# Focus (vim keys)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Split
bindsym $mod+b split h
bindsym $mod+v split v

# Fullscreen
bindsym $mod+f fullscreen toggle

# Layout
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Floating
bindsym $mod+Shift+space floating toggle

# Focus parent
bindsym $mod+a focus parent

# Reload / restart
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

# Resize
mode "resize" {
        bindsym h resize shrink width 5 px or 5 ppt
        bindsym j resize grow height 5 px or 5 ppt
        bindsym k resize shrink height 5 px or 5 ppt
        bindsym l resize grow width 5 px or 5 ppt
        bindsym Left resize shrink width 5 px or 5 ppt
        bindsym Down resize grow height 5 px or 5 ppt
        bindsym Up resize shrink height 5 px or 5 ppt
        bindsym Right resize grow width 5 px or 5 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# =============================================================================
# WORKSPACES
# =============================================================================

set $ws1 "1:One"
set $ws2 "2:Two"
set $ws3 "3:Three"
set $ws4 "4:Four"
set $ws5 "5:Five"
set $ws6 "6:Six"
set $ws7 "7:Seven"
set $ws8 "8:Eight"
set $ws9 "9:Nine"
set $ws10 "10:Ten"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# =============================================================================
# APPEARANCE
# =============================================================================

# No title bars, thick borders (addy-dclxvi style)
default_border pixel 4
default_floating_border pixel 4
hide_edge_borders smart
for_window [class=".*"] border pixel 4

# Gaps
gaps inner 12
gaps outer 0
smart_gaps on

# Window rules (floating for media/archive apps)
for_window [class=Eog|Sxiv|feh|mpv|Vlc|File-roller|Xarchiver] floating enable
for_window [class=Eog|Sxiv|feh|mpv|Vlc|File-roller|Xarchiver] focus

# Nord colors         border    bg        text      indicator child_border
client.focused          #bf616a   #3b4252   #d8dee9   #b48ead   #5e81ac
client.focused_inactive #4c566a   #3b4252   #d8dee9   #4c566a   #4c566a
client.unfocused        #4c566a   #3b4252   #4c566a   #4c566a   #4c566a
client.urgent           #bf616a   #ebcb8b   #3b4252   #bf616a   #bf616a
client.placeholder      #3b4252   #3b4252   #d8dee9   #3b4252   #3b4252
client.background       #2e3440

# =============================================================================
# BAR
# =============================================================================

bar {
        status_command i3status -c ~/.config/i3status/config
        position bottom
        workspace_min_width 48
        padding 2px 8px 2px 8px
        strip_workspace_numbers yes
        tray_output primary

        colors {
            background #2e3440
            statusline #d8dee9
            separator  #2e3440

            focused_workspace  #2e3440   #2e3440   #5e81ac
            active_workspace   #2e3440   #2e3440   #d8dee9
            inactive_workspace #2e3440   #2e3440   #4c566a
            urgent_workspace   #2e3440   #bf616a   #eceff4
            binding_mode       #2e3440   #b48ead   #eceff4
        }
}

# =============================================================================
# MULTI-MONITOR
# =============================================================================

exec_always --no-startup-id xrandr \
    --output HDMI-A-0 --mode 1920x1080 --pos 0x0 --primary \
    --output eDP --mode 2880x1800 --pos 0x1080 --scale 0.6667x0.6667

workspace 1 output HDMI-A-0
workspace 2 output HDMI-A-0
workspace 3 output HDMI-A-0
workspace 4 output HDMI-A-0
workspace 5 output HDMI-A-0
workspace 6 output eDP
workspace 7 output eDP
workspace 8 output eDP
workspace 9 output eDP
workspace 10 output eDP

bindsym $mod+p move workspace to output up
bindsym $mod+o move workspace to output down

# =============================================================================
# WALLPAPER
# =============================================================================

exec_always --no-startup-id feh --randomize --bg-fill ~/Pictures/wallpapers/*
